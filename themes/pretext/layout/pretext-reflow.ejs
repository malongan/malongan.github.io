<article class="max-w-wide mx-auto">
  <header class="mb-8 sm:mb-12 max-w-content mx-auto">
    <h1 class="font-heading text-3xl sm:text-4xl font-medium leading-tight">
      <%= page.title || 'Untitled' %>
    </h1>
    <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-text-secondary dark:text-text-secondary-dark">
      <time datetime="<%= date_xml(page.date) %>">
        <%= __('post.posted_on') || 'Posted on' %> <%= date(page.date, config.date_format) %>
      </time>
      <% if (page.tags && page.tags.length) { %>
      <span class="flex items-center gap-1">
        <% page.tags.forEach(function(tag, i) { %>
        <a href="<%- url_for(tag.path) %>" class="hover:text-accent dark:hover:text-accent-dark transition-colors">#<%= tag.name %></a>
        <% }) %>
      </span>
      <% } %>
    </div>
    <p class="mt-4 text-sm text-text-secondary dark:text-text-secondary-dark border border-border-light dark:border-border-dark rounded-lg px-3 py-2 inline-block">
      &#x1f430; Drag the bunny to see real-time text reflow powered by <a href="https://github.com/chenglou/pretext" class="text-accent dark:text-accent-dark hover:underline" target="_blank" rel="noopener">@chenglou/pretext</a>
    </p>
  </header>

  <%- partial('_partial/pretext/reflow-demo') %>

  <footer class="mt-12 pt-8 border-t border-border-light dark:border-border-dark max-w-wide mx-auto px-4 sm:px-6 lg:px-8">
    <% if (page.tags && page.tags.length) { %>
    <div class="flex flex-wrap items-center gap-2 mb-6">
      <span class="text-sm text-text-secondary dark:text-text-secondary-dark"><%= __('post.tags') || 'Tags' %>:</span>
      <% page.tags.forEach(function(tag) { %>
      <a href="<%- url_for(tag.path) %>" class="inline-block px-2.5 py-0.5 text-xs rounded-full border border-border-light dark:border-border-dark text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark hover:border-accent dark:hover:border-accent-dark transition-colors">
        #<%= tag.name %>
      </a>
      <% }) %>
    </div>
    <% } %>

    <nav class="flex justify-between items-center mt-8">
      <% if (page.prev) { %>
      <a href="<%- url_for(page.prev.path) %>" class="text-sm text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark transition-colors">
        &larr; <%= page.prev.title || 'Prev' %>
      </a>
      <% } else { %><span></span><% } %>
      <% if (page.next) { %>
      <a href="<%- url_for(page.next.path) %>" class="text-sm text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark transition-colors text-right">
        <%= page.next.title || 'Next' %> &rarr;
      </a>
      <% } %>
    </nav>
  </footer>
</article>
