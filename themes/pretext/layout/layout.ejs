<!DOCTYPE html>
<html lang="<%= config.language || 'en' %>">
<head>
  <%- fragment_cache('head', function() { return partial('_partial/head'); }) %>
</head>
<body class="bg-bg-light dark:bg-bg-dark text-text-primary dark:text-text-primary-dark font-body leading-relaxed min-h-screen flex flex-col ">
  <%- fragment_cache('header', function() { return partial('_partial/header'); }) %>
  <main class="flex-1 w-full max-w-wide mx-auto px-4 sm:px-6 lg:px-8 py-8 sm:py-12">
    <%- body %>
  </main>
  <%- fragment_cache('footer', function() { return partial('_partial/footer'); }) %>
  <% if (theme.features && theme.features.back_to_top) { %>
  <button id="back-to-top" class="fixed bottom-6 right-6 w-10 h-10 bg-accent dark:bg-accent-dark text-white rounded-full opacity-0 pointer-events-none transition-opacity duration-300 flex items-center justify-center hover:opacity-90 z-50" aria-label="Back to top">
    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 15l7-7 7 7"/></svg>
  </button>
  <% } %>
  <%- js('js/main.js') %>
</body>
</html>
