<article class="max-w-content mx-auto">
  <header class="mb-8 sm:mb-12">
    <div class="flex items-start gap-4">
      <% if (theme.pretext && theme.pretext.post_ornament && theme.pretext.post_ornament.enable) { %>
      <%- partial('pretext/post-ornament') %>
      <% } %>
      <div class="flex-1">
        <h1 class="font-heading text-3xl sm:text-4xl font-medium leading-tight">
          <%= page.title || (__('post.untitled') || 'Untitled') %>
        </h1>
        <div class="mt-3 flex flex-wrap items-center gap-3 text-sm text-text-secondary dark:text-text-secondary-dark">
          <time datetime="<%= date_xml(page.date) %>">
            <%= __('post.posted_on') || 'Posted on' %> <%= date(page.date, config.date_format) %>
          </time>
          <% if (page.updated && page.updated.isAfter && page.updated.isAfter(page.date)) { %>
          <span>
            &middot; <%= __('post.updated_on') || 'Updated on' %> <%= date(page.updated, config.date_format) %>
          </span>
          <% } %>
          <% if (theme.features && theme.features.word_count && page.content) { %>
          <span>&middot; <%= strip_html(page.content).length %> <%= __('post.words') || 'words' %></span>
          <% } %>
        </div>
      </div>
    </div>
    <% if (page.photos && page.photos.length) { %>
    <div class="mt-6 overflow-hidden rounded">
      <% page.photos.forEach(function(photo) { %>
      <img src="<%- url_for(photo) %>" alt="<%= page.title || 'Post image' %>" class="w-full h-auto" loading="lazy">
      <% }) %>
    </div>
    <% } %>
  </header>

  <% if (theme.features && theme.features.toc && page.toc !== false) { %>
  <%- partial('toc') %>
  <% } %>

  <div class="prose prose-lg dark:prose-invert max-w-none overflow-x-hidden
    prose-headings:font-heading prose-headings:font-medium
    prose-a:text-accent dark:prose-a:text-accent-dark prose-a:no-underline hover:prose-a:underline
    prose-img:rounded prose-img:mx-auto
    prose-code:font-mono prose-code:text-sm
    prose-pre:bg-gray-50 dark:prose-pre:bg-gray-900 prose-pre:rounded-lg
    prose-blockquote:border-accent dark:prose-blockquote:border-accent-dark
    prose-blockquote:not-italic">
    <%- page.content %>
  </div>

  <footer class="mt-12 pt-8 border-t border-border-light dark:border-border-dark">
    <% if (page.tags && page.tags.length) { %>
    <div class="flex flex-wrap items-center gap-2 mb-6">
      <span class="text-sm text-text-secondary dark:text-text-secondary-dark"><%= __('post.tags') || 'Tags' %>:</span>
      <% page.tags.forEach(function(tag) { %>
      <a href="<%- url_for(tag.path) %>" class="inline-block px-2.5 py-0.5 text-xs rounded-full border border-border-light dark:border-border-dark text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark hover:border-accent dark:hover:border-accent-dark transition-colors">
        #<%= tag.name %>
      </a>
      <% }) %>
    </div>
    <% } %>

    <% if (page.categories && page.categories.length) { %>
    <div class="flex flex-wrap items-center gap-2 mb-6">
      <span class="text-sm text-text-secondary dark:text-text-secondary-dark"><%= __('post.categories') || 'Categories' %>:</span>
      <% page.categories.forEach(function(cat) { %>
      <a href="<%- url_for(cat.path) %>" class="text-sm text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark transition-colors">
        <%= cat.name %>
      </a>
      <% }) %>
    </div>
    <% } %>

    <nav class="flex justify-between items-center mt-8">
      <% if (page.prev) { %>
      <a href="<%- url_for(page.prev.path) %>" class="group flex items-center gap-2 text-sm text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark transition-colors">
        <span>&larr;</span>
        <span><%= __('post.prev') || 'Prev' %>: <%= page.prev.title || (__('post.untitled') || 'Untitled') %></span>
      </a>
      <% } else { %>
      <span></span>
      <% } %>
      <% if (page.next) { %>
      <a href="<%- url_for(page.next.path) %>" class="group flex items-center gap-2 text-sm text-text-secondary dark:text-text-secondary-dark hover:text-accent dark:hover:text-accent-dark transition-colors text-right">
        <span><%= __('post.next') || 'Next' %>: <%= page.next.title || (__('post.untitled') || 'Untitled') %></span>
        <span>&rarr;</span>
      </a>
      <% } %>
    </nav>
  </footer>
</article>
