<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5">
<title><%= page.title ? page.title + ' | ' + config.title : config.title %></title>
<% if (page.description || config.description) { %>
<meta name="description" content="<%= page.description || config.description %>">
<% } %>
<% if (page.keywords || config.keywords) { %>
<meta name="keywords" content="<%= Array.isArray(page.keywords) ? page.keywords.join(',') : (page.keywords || config.keywords) %>">
<% } %>
<meta name="author" content="<%= config.author %>">
<meta property="og:type" content="<%= is_post() ? 'article' : 'website' %>">
<meta property="og:title" content="<%= page.title || config.title %>">
<meta property="og:site_name" content="<%= config.title %>">
<% if (page.description || config.description) { %>
<meta property="og:description" content="<%= page.description || config.description %>">
<% } %>
<link rel="icon" href="<%- url_for('/favicon.png') %>" type="image/png">
<link rel="canonical" href="<%= url %>">
<% if (theme.rss) { %>
<link rel="alternate" href="<%= url_for(theme.rss) %>" title="<%= config.title %>" type="application/atom+xml">
<% } %>
<% if (theme.seo && theme.seo.google_site_verification) { %>
<meta name="google-site-verification" content="<%= theme.seo.google_site_verification %>">
<% } %>

<%# Google Fonts %>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;700&family=Noto+Serif+JP:wght@400;500;700&family=Noto+Serif+SC:wght@400;500;700&family=Shippori+Mincho:wght@400;500;700&display=swap" rel="stylesheet">

<%# Theme CSS %>
<%- css('css/style.css') %>

<%# Dark mode init (inline to prevent FOUC) %>
<script>
(function(){
  var t = localStorage.getItem('theme');
  if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
    document.documentElement.classList.add('dark');
  }
})();
</script>

<% if (theme.seo && theme.seo.google_analytics) { %>
<script async src="https://www.googletagmanager.com/gtag/js?id=<%= theme.seo.google_analytics %>"></script>
<script>
  window.dataLayer = window.dataLayer || [];
  function gtag(){dataLayer.push(arguments);}
  gtag('js', new Date());
  gtag('config', '<%= theme.seo.google_analytics %>');
</script>
<% } %>
