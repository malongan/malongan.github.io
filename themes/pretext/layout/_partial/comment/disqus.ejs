<% var shortname = theme.comments.disqus && theme.comments.disqus.shortname ? theme.comments.disqus.shortname : config.disqus_shortname; %>
<% if (shortname) { %>
<div id="disqus_thread"></div>
<script>
  var disqus_shortname = '<%= shortname %>';
  var disqus_config = function () {
    this.page.url = '<%= page.permalink %>';
    this.page.identifier = '<%= page.path %>';
  };
  (function() {
    var d = document.createElement('script');
    d.type = 'text/javascript';
    d.async = true;
    d.src = '//' + disqus_shortname + '.disqus.com/embed.js';
    (document.head || document.body).appendChild(d);
  })();
</script>
<noscript>Please enable JavaScript to view the <a href="https://disqus.com/?ref_noscript">comments powered by Disqus.</a></noscript>
<% } %>
